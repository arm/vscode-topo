{
    "name": "topo",
    "displayName": "Arm Topo",
    "publisher": "arm",
    "description": "",
    "license": "Apache-2.0",
    "version": "0.0.0",
    "engines": {
        "vscode": "^1.99.0",
        "node": "22",
        "npm": "10"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onUri",
        "onLanguage:yaml"
    ],
    "main": "./dist/extension.js",
    "topo": {
        "version": "v5.1.1"
    },
    "contributes": {
        "commands": [
            {
                "command": "topo.initProject",
                "title": "Initialize Project",
                "category": "Arm Topo"
            },
            {
                "command": "topo.remoteClone",
                "title": "Clone Remote Project",
                "category": "Arm Topo"
            },
            {
                "command": "topo.templateClone",
                "title": "Clone Template Project",
                "category": "Arm Topo"
            },
            {
                "command": "topo.localClone",
                "title": "Clone Local Project",
                "category": "Arm Topo"
            },
            {
                "command": "topo.attachVsCode",
                "title": "Attach VS Code",
                "category": "Arm Topo"
            },
            {
                "command": "topo.attachShell",
                "title": "Attach Shell",
                "category": "Arm Topo"
            },
            {
                "command": "topo.openInBrowser",
                "title": "Open in Browser",
                "category": "Arm Topo"
            },
            {
                "command": "topo.startContainer",
                "title": "Start",
                "category": "Arm Topo"
            },
            {
                "command": "topo.stopContainer",
                "title": "Stop",
                "category": "Arm Topo"
            },
            {
                "command": "topo.deleteContainer",
                "title": "Delete",
                "category": "Arm Topo"
            },
            {
                "command": "topo.selectTarget",
                "title": "Select Target",
                "category": "Arm Topo"
            },
            {
                "command": "topo.removeTarget",
                "title": "Remove Target",
                "category": "Arm Topo"
            },
            {
                "command": "topo.addTarget",
                "title": "Add Target",
                "icon": "$(add)",
                "category": "Arm Topo"
            },
            {
                "command": "topo.inspectTargetHealth",
                "title": "Inspect Health",
                "category": "Arm Topo"
            },
            {
                "command": "topo.setupKeys",
                "title": "Setup Keys",
                "category": "Arm Topo"
            },
            {
                "command": "topo.installDependency",
                "title": "Install",
                "category": "Arm Topo"
            },
            {
                "command": "topo.inspectHostHealth",
                "title": "Inspect Host Health",
                "category": "Arm Topo"
            },
            {
                "command": "topo.refreshHostDependencies",
                "title": "Refresh",
                "icon": "$(refresh)",
                "category": "Arm Topo"
            },
            {
                "command": "topo.showOutput",
                "title": "Open Arm Topo Output",
                "category": "Arm Topo"
            },
            {
                "command": "topo.deploy.context",
                "title": "Topo Deploy",
                "category": "Arm Topo"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "topo",
                    "title": "Topo",
                    "icon": "media/device.svg"
                }
            ]
        },
        "views": {
            "topo": [
                {
                    "id": "topo.host-manager",
                    "name": "Host",
                    "visibility": "visible",
                    "icon": "$(vm-small)"
                },
                {
                    "id": "topo.target-manager",
                    "name": "Targets",
                    "visibility": "visible",
                    "icon": "media/device.svg"
                }
            ]
        },
        "viewsWelcome": [
            {
                "view": "topo.target-manager",
                "contents": "No targets found\n[Add Target](command:topo.addTarget)"
            }
        ],
        "menus": {
            "editor/title/context": [
                {
                    "command": "topo.deploy.context",
                    "group": "topo",
                    "when": "resourceFilename =~ /compose(\\..*)?\\.yaml$/"
                }
            ],
            "explorer/context": [
                {
                    "command": "topo.deploy.context",
                    "group": "topo",
                    "when": "resourceFilename =~ /compose(\\..*)?\\.yaml$/"
                }
            ],
            "commandPalette": [
                {
                    "command": "topo.addTarget",
                    "when": "false"
                },
                {
                    "command": "topo.selectTarget",
                    "when": "false"
                },
                {
                    "command": "topo.removeTarget",
                    "when": "false"
                },
                {
                    "command": "topo.inspectTargetHealth",
                    "when": "false"
                },
                {
                    "command": "topo.setupKeys",
                    "when": "false"
                },
                {
                    "command": "topo.installDependency",
                    "when": "false"
                },
                {
                    "command": "topo.stopContainer",
                    "when": "false"
                },
                {
                    "command": "topo.startContainer",
                    "when": "false"
                },
                {
                    "command": "topo.deleteContainer",
                    "when": "false"
                },
                {
                    "command": "topo.attachVsCode",
                    "when": "false"
                },
                {
                    "command": "topo.attachShell",
                    "when": "false"
                },
                {
                    "command": "topo.openInBrowser",
                    "when": "false"
                },
                {
                    "command": "topo.deploy.context",
                    "when": "false"
                },
                {
                    "command": "topo.refreshHostDependencies",
                    "when": "false"
                },
                {
                    "command": "topo.showOutput",
                    "when": "false"
                }
            ],
            "view/item/context": [
                {
                    "command": "topo.showOutput",
                    "when": "view == topo.host-manager && viewItem =~ /Dependencies/ && viewItem =~ /Error/",
                    "group": "topo/1_output"
                },
                {
                    "command": "topo.selectTarget",
                    "when": "view == topo.target-manager && viewItem =~ /Target/",
                    "group": "topo/1_select"
                },
                {
                    "command": "topo.inspectTargetHealth",
                    "when": "view === topo.target-manager && viewItem =~ /Target/ && viewItem =~ /Selected/",
                    "group": "topo/2_actions"
                },
                {
                    "command": "topo.setupKeys",
                    "when": "view === topo.target-manager && viewItem =~ /Target/ && viewItem =~ /Selected/",
                    "group": "topo/2_actions"
                },
                {
                    "command": "topo.removeTarget",
                    "when": "view == topo.target-manager && viewItem =~ /Target/",
                    "group": "topo/3_cleanup"
                },
                {
                    "command": "topo.installDependency",
                    "when": "view === topo.target-manager && viewItem =~ /Installable/",
                    "group": "topo/1_manage"
                },
                {
                    "command": "topo.attachVsCode",
                    "when": "view === topo.target-manager && viewItem =~ /service/ && viewItem =~ /running/ && viewItem =~ /Host/",
                    "group": "topo/attach@1"
                },
                {
                    "command": "topo.attachShell",
                    "when": "view === topo.target-manager && viewItem =~ /service/ && viewItem =~ /running/ && viewItem =~ /Host/",
                    "group": "topo/attach@1"
                },
                {
                    "command": "topo.openInBrowser",
                    "when": "view === topo.target-manager && viewItem =~ /service/ && viewItem =~ /running/ && viewItem =~ /Host/",
                    "group": "topo/attach@1"
                },
                {
                    "command": "topo.startContainer",
                    "when": "view === topo.target-manager && viewItem =~ /service/ && viewItem =~ /exited/",
                    "group": "topo/manage@1"
                },
                {
                    "command": "topo.stopContainer",
                    "when": "view === topo.target-manager && viewItem =~ /service/ && viewItem =~ /running/",
                    "group": "topo/manage@1"
                },
                {
                    "command": "topo.deleteContainer",
                    "when": "view === topo.target-manager && viewItem =~ /service/",
                    "group": "topo/manage@2"
                }
            ],
            "view/title": [
                {
                    "command": "topo.addTarget",
                    "when": "view == topo.target-manager",
                    "group": "navigation"
                },
                {
                    "command": "topo.refreshHostDependencies",
                    "when": "view == topo.host-manager",
                    "group": "navigation"
                }
            ]
        },
        "configuration": {
            "title": "Topo",
            "properties": {
                "topo.loggingVerbosity": {
                    "type": "string",
                    "enum": [
                        "off",
                        "error",
                        "warn",
                        "info",
                        "debug"
                    ],
                    "default": "warn",
                    "description": "Specify the logging verbosity of the Topo extension"
                }
            }
        }
    },
    "scripts": {
        "package": "npm run build && vsce package",
        "clean": "git clean -f -x ./node_modules ./dist ./resources ./coverage",
        "lint": "npm run prettier-check && npm run eslint-check && npm run tsc-check",
        "test": "jest --passWithNoTests --coverage",
        "build": "vite build --mode extension",
        "watch": "vite build --mode extension --watch --minify=false",
        "download": "node --no-warnings --experimental-strip-types scripts/download.ts",
        "calculate-new-version": "node --no-warnings --experimental-strip-types scripts/calculate-new-version.ts",
        "prettier-check": "prettier -c .",
        "eslint-check": "eslint .",
        "tsc-check": "tsc --noEmit -p src/tsconfig.json"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@swc/core": "^1.15.24",
        "@swc/jest": "^0.2.39",
        "@types/jest": "^30.0.0",
        "@types/node": "^22.19.15",
        "@types/vscode": "^1.99.1",
        "@typescript-eslint/eslint-plugin": "^8.58.2",
        "@typescript-eslint/parser": "^8.58.2",
        "@vscode/vsce": "^3.6.2",
        "eslint": "^10.2.1",
        "extract-zip": "^2.0.1",
        "globals": "^17.5.0",
        "jest": "^30.3.0",
        "jest-mock-extended": "^4.0.0",
        "prettier": "^3.7.4",
        "tar": "^7.5.2",
        "typescript": "^6.0.2",
        "vite": "^8.0.10",
        "yargs": "^18.0.0"
    },
    "dependencies": {
        "ssh-config": "^5.1.0",
        "superstruct": "^2.0.2",
        "vscode-uri": "^3.1.0"
    },
    "overrides": {
        "jest-mock-extended": {
            "typescript": "$typescript"
        }
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/Arm/vscode-topo.git"
    }
}
