// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "npm: watch",
            "dependsOn": ["npm: watch:extension", "npm: watch:webview"],
            "presentation": {
                "reveal": "never",
                "group": "watchers"
            },
            "dependsOrder": "parallel",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "type": "npm",
            "script": "watch:extension",
            "label": "npm: watch:extension",
            "problemMatcher": [
                {
                    "owner": "vite",
                    "pattern": {
                        "regexp": "^error during build:\\s+(.*)$",
                        "message": 1
                    },
                    "background": {
                        "activeOnStart": true,
                        "beginsPattern": "^build started\\.\\.\\.$",
                        "endsPattern": "^built in \\d+ms\\.$"
                    }
                }
            ],
            "isBackground": true,
            "presentation": {
                "reveal": "never",
                "group": "watchers"
            },
            "group": "build"
        },
        {
            "type": "npm",
            "script": "watch:webview",
            "label": "npm: watch:webview",
            "problemMatcher": [
                {
                    "owner": "vite",
                    "pattern": {
                        "regexp": "^error during build:\\s+(.*)$",
                        "message": 1
                    },
                    "background": {
                        "activeOnStart": true,
                        "beginsPattern": "^build started\\.\\.\\.$",
                        "endsPattern": "^built in \\d+ms\\.$"
                    }
                }
            ],
            "isBackground": true,
            "presentation": {
                "reveal": "never",
                "group": "watchers"
            },
            "group": "build"
        },
        {
            "type": "npm",
            "script": "build",
            "label": "npm: build",
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "npm: install",
            "type": "shell",
            "command": "npm",
            "args": ["install"],
            "problemMatcher": []
        },
        {
            "label": "npm: install and build",
            "dependsOrder": "sequence",
            "dependsOn": ["npm: install", "npm: build"],
            "problemMatcher": []
        },
        {
            "type": "npm",
            "script": "watch-tests",
            "label": "npm: watch-tests",
            "problemMatcher": "$tsc-watch",
            "isBackground": true,
            "presentation": {
                "reveal": "never",
                "group": "watchers"
            },
            "group": "build"
        }
    ]
}
